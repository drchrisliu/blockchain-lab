                      onclick="return trackOutboundLink('publications', 'click', 'liu-bodorik-jutla-transformingautomaticallybpmnmodelstosmartcontractswithnestedcollaborativetransactionstabs-2024', 'https://blockchain.cs.dal.ca/works/9%20ACM%20DLT%2023%20BPMNtoSC-ACM-DLT-submitted.pdf', event);"
